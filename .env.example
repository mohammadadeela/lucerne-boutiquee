# ── Database ──────────────────────────────────────────────────────────────────
# Add ?sslmode=require at the end for Render / hosted PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Session ───────────────────────────────────────────────────────────────────
# Any long random string (Render can auto-generate this)
SESSION_SECRET=change_me_to_a_long_random_string

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email / Gmail SMTP ────────────────────────────────────────────────────────
EMAIL_USER=your_gmail@gmail.com
# 16-character Gmail App Password (not your account password)
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ── Stripe (optional – only if using Stripe payments) ────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Firebase (optional – only if using Google/Facebook social login) ──────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ── Admin notifications ───────────────────────────────────────────────────────
# Email address that receives order/admin notifications (can be same as EMAIL_USER)
ADMIN_EMAIL=your_admin@gmail.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Render URL (or custom domain) in production, e.g. https://myapp.onrender.com
# Leave unset to allow all origins (fine for single-server full-stack deployments)
CORS_ORIGIN=

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is set automatically by Render — do not set this manually on Render
PORT=3000
